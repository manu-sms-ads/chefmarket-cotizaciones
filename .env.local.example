# ─────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — Chef Market Cotizaciones
# ─────────────────────────────────────────────────────────────────
# Copia este archivo como ".env.local" para desarrollo local,
# y carga las mismas variables en Vercel (Settings → Environment Variables).
# NUNCA subas ".env.local" a Git.
# ─────────────────────────────────────────────────────────────────

# ── Google Sheets ─────────────────────────────────────────────────
# ID del Google Sheet (el largo string en la URL de la hoja)
# Ejemplo URL: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Nombre de la pestaña/hoja dentro del Spreadsheet (puede dejarse por defecto)
GOOGLE_SHEET_NAME=Cotizaciones

# ── Cuenta de Servicio de Google ──────────────────────────────────
# Estos valores vienen del JSON que descargaste al crear la cuenta de servicio
GOOGLE_PROJECT_ID=tu-proyecto-id
GOOGLE_PRIVATE_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ⚠️  La private key debe incluir los saltos de línea como \n (no literales)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=chefmarket-sheets@tu-proyecto.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=000000000000000000000
